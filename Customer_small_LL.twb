    <worksheet name='The Customer Lens'>
      <layout-options>
        <title>
          <formatted-text>
            <run>The Customer Lens&#10;</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='The LocalLens' name='federated.0x8vjjp1kopqt61g9s7sx1sijnrd' />
            <datasource name='Parameters' />
          </datasources>
          <mapsources>
            <mapsource name='Tableau' />
          </mapsources>
          <datasource-dependencies datasource='Parameters'>
            <column caption='Rating type' datatype='string' name='[Parameter 2]' param-domain-type='list' role='measure' type='nominal' value='&quot;Overall City Relative Score&quot;'>
              <calculation class='tableau' formula='&quot;Overall City Relative Score&quot;' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.0x8vjjp1kopqt61g9s7sx1sijnrd'>
            <column datatype='string' name='[CI_for_avg_rating]' role='dimension' type='nominal' />
            <column caption='Score' datatype='real' name='[Calculation_5690568096645122]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='CASE [Parameters].[Parameter 2]&#10;&#10;WHEN &quot;Niche Competition Score&quot; THEN float([competition_score])&#10;&#10;WHEN &quot;Broad Competition Score&quot; THEN FLOAT([broad_competition_score])&#10;&#10;WHEN &quot;Overall Category Relative Score&quot; THEN FLOAT([category_relative_score])&#10;&#10;WHEN &quot;Overall City Relative Score&quot; THEN FLOAT([standardized_city_rating])&#10;&#10;END' />
            </column>
            <column caption='CI Upper' datatype='real' name='[Calculation_5690568103673859]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='FLOAT(&#10;REGEXP_EXTRACT([CI_for_avg_rating], &apos;,\s*(?:np.float64\()?([0-9\.]+)&apos;)&#10;)' />
            </column>
            <column caption='CI Lower' datatype='real' name='[Calculation_5690568103940101]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='FLOAT(&#10;REGEXP_EXTRACT([CI_for_avg_rating], &apos;\((?:np.float64\()?([0-9\.]+)&apos;)&#10;)' />
            </column>
            <column caption='Likely Rating Range' datatype='string' name='[Calculation_5690568104345606]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='STR(ROUND([Calculation_5690568103940101],3)) + &quot; – &quot; + STR(ROUND([Calculation_5690568103673859],3))' />
            </column>
            <column caption='Score Label' datatype='string' name='[Calculation_5690568106758151]' role='dimension' type='nominal'>
